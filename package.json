{
	"name": "reality-scraper",
	"version": "1.0.0",
	"description": "Scraper for Czech real estate listings",
	"main": "src/index.ts",
	"scripts": {
		"start-ts": "ts-node --transpile-only src/index.ts",
		"start": "node dist/index.js",
		"build": "tsc",
		"dev": "ts-node-dev --respawn --transpile-only src/index.ts",
		"supabase:local:start": "./scripts/supabase-local.sh start",
		"supabase:local:stop": "./scripts/supabase-local.sh stop",
		"supabase:local:status": "./scripts/supabase-local.sh status",
		"supabase:local:sync-env": "./scripts/supabase-local.sh sync-env",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"manual-scrape-idnes": "ts-node --transpile-only scripts/manual-scrape-idnes.ts",
		"manual-scrape-bezrealitky": "ts-node --transpile-only scripts/manual-scrape-bezrealitky.ts",
		"manual-scrape-sreality": "ts-node --transpile-only scripts/manual-scrape-sreality.ts",
		"manual-scrape-bazos": "ts-node --transpile-only scripts/manual-scrape-bazos.ts",
		"manual-scrape-okdrazby": "ts-node --transpile-only scripts/manual-scrape-okdrazby.ts",
		"manual-scrape-exdrazby": "ts-node --transpile-only scripts/manual-scrape-exdrazby.ts",
		"normalize-property-areas": "ts-node --transpile-only scripts/normalize-property-areas.ts",
		"backfill-price-per-sqm": "ts-node --transpile-only scripts/backfill-price-per-sqm.ts",
		"backfill-idnes-area-from-title": "ts-node --transpile-only scripts/backfill-idnes-area-from-title.ts",
		"average-price-per-sqm-by-source": "ts-node --transpile-only scripts/average-price-per-sqm-by-source.ts",
		"log-urls": "ts-node --transpile-only scripts/log-scrape-urls.ts",
		"deploy": "./scripts/deploy.sh",
		"env": "./scripts/env.sh",
		"env:show": "./scripts/env.sh show"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.89.0",
		"cheerio": "^1.0.0-rc.12",
		"dotenv": "^16.4.5",
		"node-cron": "^3.0.3",
		"node-telegram-bot-api": "^0.66.0",
		"puppeteer": "^24.9.0"
	},
	"devDependencies": {
		"@flydotio/dockerfile": "^0.7.10",
		"@types/node": "^20.0.0",
		"@types/node-cron": "^3.0.11",
		"@types/node-telegram-bot-api": "^0.64.7",
		"@vitest/coverage-v8": "^4.0.16",
		"ts-node": "^10.9.0",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.0.0",
		"vitest": "^4.0.16"
	}
}
