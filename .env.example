# Telegram Bot Configuration (REQUIRED)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Override search parameters
# PRICE_MIN=3000000
# PRICE_MAX=6000000
# CITY=brno
# ROOMS=2k|21
# AREA_MIN=36
# OWNERSHIP=personal
# MATERIAL=brick|wood|stone|skeleton|prefab|mixed
# ROOM_COUNT=3

# Development: Set to true to run scrape immediately on start
# RUN_NOW=true
# Supabase Database Configuration (optional - enables deduplication)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
